# Copy this file to .env and fill in your values
# DO NOT commit .env to git — it contains your secret token

# 1. Go to https://www.notion.so/my-integrations
# 2. Create an integration → copy the token below
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# For each database: open it in Notion, copy the ID from the URL
# URL looks like: notion.so/workspace/PAGE_TITLE-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX?v=...
# The database ID is the 32-char hex string before the ?v=

DB_TRADES=
DB_DAILY=
DB_MONTHLY=
DB_WEEKLY=
DB_ACCOUNTS=
DB_TRANSACTIONS=
DB_NOTES=
DB_JOURNAL=
